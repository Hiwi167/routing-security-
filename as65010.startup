#!/bin/sh
sysctl -w net.ipv4.ip_forward=1
ip addr add 10.0.110.2/30 dev eth0
ip link set eth0 up
ip addr add 172.16.10.1/24 dev lo
ip link set lo up

ip route add default via 10.0.110.1
echo "nameserver 8.8.8.8" > /etc/resolv.conf


pkill -9 bgpd || true
rm -f /var/run/bgpd.sock

# Move and Start
cp /bgpd.conf /etc/bgpd.conf




# 3. Start your custom BGP
/usr/sbin/bgpd -f /etc/bgpd.conf

ps aux | grep bgpd
