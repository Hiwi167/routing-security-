#!/bin/sh
sysctl -w net.ipv4.ip_forward=1
ip addr add 10.0.99.2/30 dev eth0
ip link set eth0 up
ip addr add 172.16.2.1/25 dev lo
ip addr add 172.16.3.1/32 dev lo
ip link set lo up
ip addr add 10.0.19.1/30 dev eth1
ip link set eth1 up

pkill -9 bgpd || true
rm -f /var/run/bgpd.sock

# 3. Move the pre-made config to the right place
cp /bgpd.conf /etc/bgpd.conf



# 3. Start your custom BGP
/usr/sbin/bgpd -f /etc/bgpd.conf


ps aux | grep bgpd
